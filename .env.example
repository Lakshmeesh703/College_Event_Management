# Copy to .env and fill in your values (never commit .env)

# Flask
SECRET_KEY=change-this-to-a-random-string

# --- Database (pick ONE approach) ---

# Option A: single connection URL (Render, Railway, Neon, Supabase, etc.)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Option B: local PostgreSQL — DB_PASSWORD must match your postgres user (see: sudo -u postgres psql)
# If you see "fe_sendauth: no password supplied", you forgot DB_PASSWORD or DATABASE_URL here.
DB_USER=postgres
DB_PASSWORD=your_actual_postgres_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=college_events

# --- Optional SMTP settings for OTP emails ---
# If unset, OTP is printed in server logs for development.
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your_email@gmail.com
# MAIL_PASSWORD=your_app_password
# MAIL_FROM=your_email@gmail.com
# MAIL_USE_TLS=1
